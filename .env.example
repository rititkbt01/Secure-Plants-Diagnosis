# ═══════════════════════════════════════════════════════
# Secure-Plants_Diagnosis — Environment Variables
# Copy this file: cp .env.example .env
# Fill in your values. NEVER commit .env to Git.
# ═══════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────
APP_NAME=Secure-Plants_Diagnosis
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=True

# ── Server ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── PostgreSQL Database ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=plant_diagnosis_db
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DATABASE_URL=postgresql://your_db_username:your_db_password@localhost:5432/plant_diagnosis_db

# ── JWT Authentication ────────────────────────────────
JWT_SECRET_KEY=your-very-strong-secret-key-here-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security ─────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=5
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── ML Model ─────────────────────────────────────────
MODEL_PATH=models/student/deit_tiny_plant_diagnosis.pth
MODEL_INPUT_SIZE=224
MODEL_NUM_CLASSES=15
INFERENCE_DEVICE=cpu